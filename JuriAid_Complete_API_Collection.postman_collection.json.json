    { "key": "token",            "value": "" }
  ],
  "item": [

    {
      "name": "🔐 1. Auth Service (Port 8001)",
      "item": [
        {
          "name": "Root - Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{auth_url}}/", "host": ["{{auth_url}}"], "path": [""] }
          }
        },
        {
          "name": "Signup - Register New User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"kumari@juriaid.lk\",\n  \"password\": \"SecurePass@123\",\n  \"full_name\": \"Kumari Silva\",\n  \"phone\": \"+94771234567\"\n}"
            },
            "url": { "raw": "{{auth_url}}/auth/signup", "host": ["{{auth_url}}"], "path": ["auth","signup"] }
          }
        },
        {
          "name": "Login - Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set('token', jsonData.access_token);",
                  "    console.log('Token saved');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"kumari@juriaid.lk\",\n  \"password\": \"SecurePass@123\"\n}"
            },
            "url": { "raw": "{{auth_url}}/auth/login", "host": ["{{auth_url}}"], "path": ["auth","login"] }
          }
        },
        {
          "name": "Verify Token",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{auth_url}}/auth/verify", "host": ["{{auth_url}}"], "path": ["auth","verify"] }
          }
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{auth_url}}/auth/me", "host": ["{{auth_url}}"], "path": ["auth","me"] }
          }
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Kumari Silva Updated\",\n  \"phone\": \"+94779876543\"\n}"
            },
            "url": { "raw": "{{auth_url}}/auth/me", "host": ["{{auth_url}}"], "path": ["auth","me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{auth_url}}/auth/logout", "host": ["{{auth_url}}"], "path": ["auth","logout"] }
          }
        },
        {
          "name": "Admin - List All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{auth_url}}/admin/users?skip=0&limit=100",
              "host": ["{{auth_url}}"],
              "path": ["admin","users"],
              "query": [
                { "key": "skip", "value": "0" },
                { "key": "limit", "value": "100" }
              ]
            }
          }
        }
      ]
    },

