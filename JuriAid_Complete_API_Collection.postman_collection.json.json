    {
      "name": "🔐 1. Auth Service (Port 8001)",
      "item": [
        {
          "name": "Root - Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{auth_url}}/",
              "host": ["{{auth_url}}"],
              "path": [""]
            },
            "description": "Returns service status, name and version"
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"status\": \"ok\",\n  \"service\": \"JuriAid Auth Service\",\n  \"version\": \"1.0.0\"\n}"
            }
          ]
        },
        {
          "name": "Signup - Register New User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"kumari@juriaid.lk\",\n  \"password\": \"SecurePass@123\",\n  \"full_name\": \"Kumari Silva\",\n  \"phone\": \"+94771234567\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/signup",
              "host": ["{{auth_url}}"],
              "path": ["auth", "signup"]
            },
            "description": "Register new user. Returns JWT token immediately. Email must be unique. Password min 6 chars."
          },
          "response": [
            {
              "name": "Success - 201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": 1,\n    \"email\": \"kumari@juriaid.lk\",\n    \"full_name\": \"Kumari Silva\",\n    \"phone\": \"+94771234567\",\n    \"is_active\": true,\n    \"role\": \"user\",\n    \"subscription_tier\": \"free\"\n  }\n}"
            },
            {
              "name": "Email Already Registered - 400",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"success\": false,\n  \"detail\": \"Email already registered\",\n  \"status_code\": 400\n}"
            }
          ]
        },
        {
          "name": "Login - Get JWT Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.access_token) {",
                  "    pm.collectionVariables.set('token', jsonData.access_token);",
                  "    console.log('✅ Token saved:', jsonData.access_token.substring(0,30) + '...');",
                  "} else {",
                  "    console.log('❌ No token in response');",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"kumari@juriaid.lk\",\n  \"password\": \"SecurePass@123\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/login",
              "host": ["{{auth_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with email and password. Returns JWT token valid for 24 hours. Token auto-saved to collection variable."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"access_token\": \"eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...\",\n  \"user\": {\n    \"id\": 1,\n    \"email\": \"kumari@juriaid.lk\",\n    \"full_name\": \"Kumari Silva\",\n    \"is_active\": true,\n    \"role\": \"user\",\n    \"subscription_tier\": \"free\"\n  }\n}"
            },
            {
              "name": "Wrong Credentials - 401",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"success\": false,\n  \"detail\": \"Incorrect email or password\",\n  \"status_code\": 401\n}"
            },
            {
              "name": "Inactive Account - 403",
              "status": "Forbidden",
              "code": 403,
              "body": "{\n  \"success\": false,\n  \"detail\": \"Account is inactive. Contact support.\",\n  \"status_code\": 403\n}"
            }
          ]
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
