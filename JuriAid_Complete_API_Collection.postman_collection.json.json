    {
      "name": "❓ 4. Question Generator (Port 8004)",
      "item": [
        {
          "name": "Generate Legal Questions",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"case_text\": \"The petitioner Kumari Silva, aged 34, married the respondent Nimal Silva, aged 38, on 15th March 2018 at the Colombo District Court. The parties lived together at No. 45, Galle Road, Colombo 03. The respondent has been guilty of adultery since January 2022 and abandoned the matrimonial home in June 2023. The petitioner seeks dissolution of marriage, custody of one minor child, monthly maintenance of LKR 50,000 and division of matrimonial property.\",\n  \"law\": \"Matrimonial Causes Ordinance No. 15 of 1907 - Section 19 Adultery, Section 20 Desertion for 2 years, Section 21 Cruelty. Maintenance Act No. 37 of 1999 - Section 2 Duty to maintain spouse and children.\",\n  \"cases\": \"Fernando v Fernando (2019) - Colombo District Court upheld divorce on adultery and desertion grounds. Perera v Perera (2021) - Supreme Court ruled physical abuse constitutes cruelty under Section 21.\"\n}"
            },
            "url": { "raw": "{{questiongen_url}}/generate-questions", "host": ["{{questiongen_url}}"], "path": ["generate-questions"] },
            "description": "Multi-agent pipeline: case_agent → law_agent → reasoning_agent → question_agent → validation_agent. Body: {case_text, law, cases}. Expect ~1 min (CPU inference)."
          },
          "response": [
            {
              "name": "Success", "status": "OK", "code": 200,
              "body": "{\n  \"questions\": \"1. What are the petitioner's rights under Matrimonial Causes Ordinance No. 15 of 1907?\\n2. Under Section 19, what evidence is required to prove adultery?\\n3. Can the petitioner claim maintenance under Maintenance Act No. 37 of 1999?\\n4. What custody arrangements can be sought for the minor child?\\n5. How might Fernando v Fernando (2019) influence this case?\"\n}"
            }
          ]
        }
      ]
    },

