        {
          "name": "Verify Token",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{auth_url}}/auth/verify",
              "host": ["{{auth_url}}"],
              "path": ["auth", "verify"]
            },
            "description": "Verify JWT token validity. Used by orchestrator to validate user. Returns user_id, email, role, subscription_tier."
          },
          "response": [
            {
              "name": "Valid Token",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"valid\": true,\n  \"user_id\": 1,\n  \"email\": \"kumari@juriaid.lk\",\n  \"role\": \"user\",\n  \"subscription_tier\": \"free\"\n}"
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{auth_url}}/auth/logout",
              "host": ["{{auth_url}}"],
              "path": ["auth", "logout"]
            },
            "description": "Logout endpoint. Validates token then instructs client to delete it."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"message\": \"Successfully logged out. Please delete your token.\"\n}"
            }
          ]
        },
        {
          "name": "Admin - List All Users",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": {
              "raw": "{{auth_url}}/admin/users?skip=0&limit=100",
              "host": ["{{auth_url}}"],
              "path": ["admin", "users"],
              "query": [
                { "key": "skip",  "value": "0" },
                { "key": "limit", "value": "100" }
              ]
            },
            "description": "Admin only endpoint. Lists all users with pagination. Role must be admin."
          },
          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"email\": \"kumari@juriaid.lk\",\n    \"full_name\": \"Kumari Silva\",\n    \"is_active\": true,\n    \"role\": \"user\",\n    \"subscription_tier\": \"free\"\n  },\n  {\n    \"id\": 2,\n    \"email\": \"admin@juriaid.lk\",\n    \"full_name\": \"Admin User\",\n    \"is_active\": true,\n    \"role\": \"admin\",\n    \"subscription_tier\": \"premium\"\n  }\n]"
