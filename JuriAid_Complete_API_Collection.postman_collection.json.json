            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"email\": \"kumari@juriaid.lk\",\n  \"full_name\": \"Kumari Silva Perera\",\n  \"phone\": \"+94779876543\",\n  \"is_active\": true,\n  \"role\": \"user\",\n  \"subscription_tier\": \"free\"\n}"
            }
          ]
