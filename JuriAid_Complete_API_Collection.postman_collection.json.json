          "response": [
            {
              "name": "Success",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"email\": \"kumari@juriaid.lk\",\n  \"full_name\": \"Kumari Silva\",\n  \"phone\": \"+94771234567\",\n  \"is_active\": true,\n  \"role\": \"user\",\n  \"subscription_tier\": \"free\"\n}"
            }
          ]
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Kumari Silva Perera\",\n  \"phone\": \"+94779876543\"\n}"
            },
            "url": {
              "raw": "{{auth_url}}/auth/me",
              "host": ["{{auth_url}}"],
              "path": ["auth", "me"]
