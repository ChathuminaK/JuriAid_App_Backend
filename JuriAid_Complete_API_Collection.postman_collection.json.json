{
  "info": {
    "name": "JuriAid - Complete API Collection v3.0",
    "description": "Full API Collection for all 5 JuriAid Backend Microservices.\nv3.0: Added all missing endpoints — Reports API, Metrics, Profile Update, Admin Users, Case File View, Search More, Timeline APIs, Amendments.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "auth_url",         "value": "http://127.0.0.1:8001" },
    { "key": "pastcase_url",     "value": "http://127.0.0.1:8002" },
    { "key": "lawstatkg_url",    "value": "http://127.0.0.1:8003" },
